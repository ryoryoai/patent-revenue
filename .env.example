# Patent Value Check - 環境変数テンプレート

# サーバー設定
PORT=3000
NODE_ENV=development

# セキュリティ
HASH_SECRET=pvc-dev-secret
METRICS_API_KEY=dev-metrics-key
EDGE_SHARED_SECRET=

# CORS
ALLOWED_ORIGINS=https://ryoryoai.github.io

# Cloudflare Turnstile (CAPTCHA)
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# LLM API (詳細レポート生成)
LLM_API_KEY=
LLM_MODEL=claude-sonnet-4-20250514
LLM_TIMEOUT_MS=30000

# メール送信 (Resend)
RESEND_API_KEY=
MAIL_FROM=noreply@patent-revenue.iprich.jp

# アラート
ALERT_WEBHOOK_URL=

# プロキシ
TRUSTED_PROXIES=
