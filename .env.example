# Patent Value Check - 環境変数テンプレート

# サーバー設定
PORT=3000
NODE_ENV=development

# セキュリティ
HASH_SECRET=pvc-dev-secret
METRICS_API_KEY=dev-metrics-key
EDGE_SHARED_SECRET=

# CORS
ALLOWED_ORIGINS=https://ryoryoai.github.io

# Cloudflare Turnstile (CAPTCHA)
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# JPO 特許情報取得API (https://ip-data.jpo.go.jp)
JPO_USERNAME=
JPO_PASSWORD=
JPO_API_TIMEOUT_MS=10000

# OpenAI API (特許検索 + 詳細レポート生成)
OPENAI_API_KEY=sk-xxx
OPENAI_MODEL=gpt-5
LLM_TIMEOUT_MS=30000

# メール送信 (Resend)
RESEND_API_KEY=
MAIL_FROM=noreply@patent-revenue.iprich.jp

# V2パイプライン (ip-rich-poc-phase2) - 構成要件充足判定
V2_API_BASE=http://localhost:8000
V2_API_TOKEN=
V2_POLL_INTERVAL_MS=10000
V2_POLL_TIMEOUT_MS=600000

# アラート
ALERT_WEBHOOK_URL=

# プロキシ
TRUSTED_PROXIES=

# Supabase (リード・特許情報保存)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
